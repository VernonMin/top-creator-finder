# ============================================
# Apify API 配置
# ============================================

# 你的 Apify API Token
# 从 https://console.apify.com/account/integrations 获取
APIFY_API_TOKEN=your_apify_token_here

# Amazon Live 爬虫 Actor ID
# 格式：username/actor-name
# 例如：yourname/amazon-live-creators-scraper
APIFY_AMAZON_LIVE_SCRAPER_ID=yourname/amazon-live-creators-scraper

# Amazon Influencers 验证 Actor ID
# 这个 Actor 已经存在在 Apify Store 上
# 使用官方提供的 Actor ID
APIFY_PROFILE_SCRAPER_ID=igview-owner/amazon-influencers-profile-scraper

# ============================================
# 服务器配置
# ============================================

# 服务器端口
PORT=3000

# 服务器地址
HOST=localhost

# ============================================
# 应用配置
# ============================================

# Node 环境
NODE_ENV=development

# CORS 允许的源（逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# ============================================
# Apify 运行配置
# ============================================

# Amazon Live 爬虫超时（秒）
APIFY_ACTOR_TIMEOUT_SECS=300

# 最大并发调用数
APIFY_MAX_CONCURRENT_RUNS=2

# ============================================
# 数据处理配置
# ============================================

# 是否自动删除已完成的 Actor 运行记录
CLEANUP_RUNS=false

# 缓存创作者信息多少秒（避免频繁调用）
CREATOR_CACHE_DURATION=3600
